<Page x:Class="Graduation.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Graduation.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1200"
      Title="AuthPage">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical">
                <ui:TextBox x:Name="LoginTextBox" Height="35" Width="140" PlaceholderText="Логин"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0 20 0 0">
                <ui:PasswordBox x:Name="PasswordTextBox" Height="60" Width="140" PlaceholderText="Пароль" TextWrapping="Wrap"/>
            </StackPanel>
            <ui:Button x:Name="LoginButton" Content="ВОЙТИ" HorizontalAlignment="Center" Height="30" Width="110" Margin="0 20 0 0" Click="LoginButton_Click"/>
        </StackPanel>
    </Grid>
</Page>

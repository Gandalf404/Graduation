<Page x:Class="Graduation.Pages.AcceptNotePages.AcceptNoteAddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Graduation.Pages.AcceptNotePages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AcceptNoteAddPage">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="WorkOrderComboBox" Height="35" Width="180" SelectedIndex="0"/>
                <ComboBox x:Name="PAUComboBox" Height="35" Width="180" Margin="20 0 0 0" SelectedIndex="0"/>
                <ComboBox x:Name="OperationComboBox" Height="35" Width="180" Margin="20 0 0 0" SelectedIndex="0"/>
            </StackPanel>
            <ui:Button x:Name="AddAcceptNoteButton" Height="30" Width="110" Margin="0 20 0 0" HorizontalAlignment="Center" Content="ДОБАВИТЬ" Click="AddAcceptNoteButton_Click"/>
        </StackPanel>
    </Grid>
</Page>

<Page x:Class="Graduation.Pages.PAUPages.PAUsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Graduation.Pages.PAUPages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1000"
      Title="PAUsPage">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="StorageNumberTextBox" Height="35" Width="180" IsEditable="True" SelectedIndex="0"/>
                <ui:SymbolIcon Symbol="Add12" Margin="20 0 0 0"/>
                <ui:TextBox x:Name="PAUNameTextBox" Height="35" Width="180" Margin="20 0 40 0" PlaceholderText="Наименование ДСЕ"/>
                <ui:TextBox x:Name="PAUCountTextBox" Height="35" Width="180" PlaceholderText="Количество ДСЕ"/>
                <ui:Image Height="200" Width="200" Margin="20 0 0 0"/>
            </StackPanel>
            <ui:Button x:Name="AddPAUButton" Height="30" Width="110" HorizontalAlignment="Center" Content="ДОБАВИТЬ" Click="AddPAUButton_Click"/>
        </StackPanel>
    </Grid>
</Page>

<Page x:Class="Graduation.Pages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Graduation.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrationPage">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <ui:TextBox x:Name="SurnameTextBox" Height="35" Width="140" PlaceholderText="Фамилия"/>
                <ui:TextBox x:Name="NameTextBox" Height="35" Width="140" Margin="20 0" PlaceholderText="Имя"/>
                <ui:TextBox x:Name="PatronymicTextBox"
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>

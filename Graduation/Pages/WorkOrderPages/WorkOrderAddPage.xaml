<Page x:Class="Graduation.Pages.WorkOrderPages.WorkOrderAddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Graduation.Pages.WorkOrderPages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WorkOrderAddPage">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="WorkerComboBox" Height="35" Width="180"/>
                <ComboBox x:Name="PAUComboBox" Height="35" Width="180" Margin="20 0 0 0"/>
                <ui:TextBox x:Name="PAUCountTextBox" Height="35" Width="180" Margin="20 0 0 0" PlaceholderText="Количество ДСЕ"/>
            </StackPanel>
            <ui:Button x:Name="WorkOrderSaveButton" HorizontalAlignment="Center" Height="30" Width="110" Margin="0 20 0 0" Content="СОХРАНИТЬ" Click="WorkOrderSaveButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
